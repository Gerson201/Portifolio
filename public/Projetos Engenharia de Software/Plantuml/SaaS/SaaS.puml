@startuml SaaS
!theme plain
skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam packageStyle rectangle
skinparam shadowing false
skinparam roundCorner 10
skinparam linetype ortho

title **SaaS**\\n<size:13>Arquitetura e Modulos Principais</size>\\n<size:11>Resumo para portifolio</size>

legend right
  |= Cor |= Camada |
  | <#1565C0> | Apresentacao |
  | <#0277BD> | Aplicacao |
  | <#00838F> | Dominio |
  | <#00695C> | Infraestrutura |
  | <#AD1457> | Observabilidade |
  | <#9E9E9E> | Dados Sigilosos (Isolado) |
end legend

package "Modulos Principais" as main <<Rectangle>> #E3F2FD {
  component [infra] as infra
}

package "Classes e Funcoes (amostra)" as code <<Rectangle>> #E8F5E9 {
  component [LoginDto] as code_1
  component [RefreshTokenDto] as code_2
  component [RegisterDto] as code_3
  component [CategoryQueryDto] as code_4
  component [CreateCategoryDto] as code_5
  component [UpdateCategoryDto] as code_6
  component [CreateMicrositeDto] as code_7
  component [MicrositeQueryDto] as code_8
  component [UpdateMicrositeDto] as code_9
  component [CreatePageDto] as code_10
  component [UpdatePageDto] as code_11
  component [CreateOrderItemDto] as code_12
  component [CreateOrderDto] as code_13
  component [OrderQueryDto] as code_14
  component [UpdateOrderDto] as code_15
  component [CreatePaymentDto] as code_16
  component [PaymentWebhookDto] as code_17
  component [CreateProductDto] as code_18
  component [ProductQueryDto] as code_19
  component [UpdateProductDto] as code_20
}

note as secrets #EEEEEE
  **Dados Sigilosos**
  ---
  Credenciais, tokens, chaves
  Variaveis de ambiente
  Configs sensiveis
end note


' ====== RELACIONAMENTOS ======
main --> code
footer \\n<size:10>SaaS - Diagrama para portifolio (sem dados sensiveis)</size>




@enduml
