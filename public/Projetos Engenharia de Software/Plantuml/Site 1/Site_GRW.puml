@startuml Site_GRW
!theme plain
skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam packageStyle rectangle
skinparam shadowing false
skinparam roundCorner 10
skinparam linetype ortho

title **Site_GRW**\\n<size:13>Arquitetura e Modulos Principais</size>\\n<size:11>Resumo para portifolio</size>

legend right
  |= Cor |= Camada |
  | <#1565C0> | Apresentacao |
  | <#0277BD> | Aplicacao |
  | <#00838F> | Dominio |
  | <#00695C> | Infraestrutura |
  | <#AD1457> | Observabilidade |
  | <#9E9E9E> | Dados Sigilosos (Isolado) |
end legend

package "Modulos Principais" as main <<Rectangle>> #E3F2FD {
  component ".claude" as claude_dir
  component "grw-engenharia" as grw_engenharia
  component "Imagens" as imagens_dir
}

package "Classes e Funcoes (amostra)" as code <<Rectangle>> #E8F5E9 {
  component [position] as code_1
  component [unclosed] as code_2
  component [endOfFile] as code_3
  component [nextToken] as code_4
  component [back] as code_5
  component [registerInput] as code_6
  component [getTokenType] as code_7
  component [terminalHighlight] as code_8
  component [CssSyntaxError] as code_9
  component [capitalize] as code_10
  component [Stringifier] as code_11
  component [stringify] as code_12
  component [cloneNode] as code_13
  component [sourceOffset] as code_14
  component [Node] as code_15
  component [Comment] as code_16
  component [Declaration] as code_17
  component [cleanSource] as code_18
  component [markTreeDirty] as code_19
  component [Container] as code_20
}

note as secrets #EEEEEE
  **Dados Sigilosos**
  ---
  Credenciais, tokens, chaves
  Variaveis de ambiente
  Configs sensiveis
end note


' ====== RELACIONAMENTOS ======
claude_dir --> grw_engenharia
grw_engenharia --> imagens_dir
main --> code
footer \\n<size:10>Site_GRW - Diagrama para portifolio (sem dados sensiveis)</size>




@enduml
