@startuml Sistema_deteccao_atividade_Raspberry
!theme plain
skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam packageStyle rectangle
skinparam shadowing false
skinparam roundCorner 10
skinparam linetype ortho

title **Sistema_deteccao_atividade_Raspberry**\\n<size:13>Arquitetura e Modulos Principais</size>\\n<size:11>Resumo para portifolio</size>

legend right
  |= Cor |= Camada |
  | <#1565C0> | Apresentacao |
  | <#0277BD> | Aplicacao |
  | <#00838F> | Dominio |
  | <#00695C> | Infraestrutura |
  | <#AD1457> | Observabilidade |
  | <#9E9E9E> | Dados Sigilosos (Isolado) |
end legend

package "Modulos Principais" as main <<Rectangle>> #E3F2FD {
  component [src] as src
  component [web] as web
}

package "Classes e Funcoes (amostra)" as code <<Rectangle>> #E8F5E9 {
  component [StreamCreateDTO] as code_1
  component [StreamResponseDTO] as code_2
  component [from_entity] as code_3
  component [StreamUpdateDTO] as code_4
  component [StreamListResponseDTO] as code_5
  component [CreateStreamUseCase] as code_6
  component [__init__] as code_7
  component [GetStreamUseCase] as code_8
  component [GetAllStreamsUseCase] as code_9
  component [UpdateStreamStatusUseCase] as code_10
  component [DeleteStreamUseCase] as code_11
  component [StreamStatus] as code_12
  component [Stream] as code_13
  component [is_active] as code_14
  component [get_rtmp_url] as code_15
  component [get_hls_url] as code_16
  component [get_dash_url] as code_17
  component [StreamRepository] as code_18
  component [StreamService] as code_19
  component [_generate_stream_key] as code_20
}

note as secrets #EEEEEE
  **Dados Sigilosos**
  ---
  Credenciais, tokens, chaves
  Variaveis de ambiente
  Configs sensiveis
end note


' ====== RELACIONAMENTOS ======
src --> web
main --> code
footer \\n<size:10>Sistema_deteccao_atividade_Raspberry - Diagrama para portifolio (sem dados sensiveis)</size>




@enduml
