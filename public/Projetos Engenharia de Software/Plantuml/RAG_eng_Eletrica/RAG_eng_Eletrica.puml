@startuml RAG_eng_Eletrica
!theme plain
skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam packageStyle rectangle
skinparam shadowing false
skinparam roundCorner 10
skinparam linetype ortho

title **RAG_eng_Eletrica**\\n<size:13>Arquitetura e Modulos Principais</size>\\n<size:11>Resumo para portifolio</size>

legend right
  |= Cor |= Camada |
  | <#1565C0> | Apresentacao |
  | <#0277BD> | Aplicacao |
  | <#00838F> | Dominio |
  | <#00695C> | Infraestrutura |
  | <#AD1457> | Observabilidade |
  | <#9E9E9E> | Dados Sigilosos (Isolado) |
end legend

package "Modulos Principais" as main <<Rectangle>> #E3F2FD {
  component [src] as src
  component [models] as models
  component [data] as data
  component [docs] as docs
  component [tests] as tests
  component [ui] as ui
}

package "Classes e Funcoes (amostra)" as code <<Rectangle>> #E8F5E9 {
  component [analyze_code_file] as code_1
  component [analyze_code_directory] as code_2
  component [compare_projects] as code_3
  component [ProjectAnalysis] as code_4
  component [ProjectAnalyzer] as code_5
  component [__init__] as code_6
  component [analyze_project_directory] as code_7
  component [_collect_code_files] as code_8
  component [_collect_doc_files] as code_9
  component [_collect_schematic_files] as code_10
  component [_read_project_files] as code_11
  component [_extract_project_name] as code_12
  component [_generate_description] as code_13
  component [_identify_technologies] as code_14
  component [_identify_components] as code_15
  component [_analyze_architecture] as code_16
  component [_check_code_quality] as code_17
  component [_identify_design_patterns] as code_18
  component [_suggest_improvements] as code_19
  component [_estimate_complexity] as code_20
}

note as secrets #EEEEEE
  **Dados Sigilosos**
  ---
  Credenciais, tokens, chaves
  Variaveis de ambiente
  Configs sensiveis
end note


' ====== RELACIONAMENTOS ======
src --> models
data --> models
main --> code
footer \\n<size:10>RAG_eng_Eletrica - Diagrama para portifolio (sem dados sensiveis)</size>




@enduml
