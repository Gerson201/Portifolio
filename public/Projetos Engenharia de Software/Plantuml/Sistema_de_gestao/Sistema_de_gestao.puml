@startuml Sistema_de_gestao
!theme plain
skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam packageStyle rectangle
skinparam shadowing false
skinparam roundCorner 10
skinparam linetype ortho

title **Sistema_de_gestao**\\n<size:13>Arquitetura e Modulos Principais</size>\\n<size:11>Resumo para portifolio</size>

legend right
  |= Cor |= Camada |
  | <#1565C0> | Apresentacao |
  | <#0277BD> | Aplicacao |
  | <#00838F> | Dominio |
  | <#00695C> | Infraestrutura |
  | <#AD1457> | Observabilidade |
  | <#9E9E9E> | Dados Sigilosos (Isolado) |
end legend

package "Modulos Principais" as main <<Rectangle>> #E3F2FD {
  component [backend] as backend
  component [frontend] as frontend
  component [scripts] as scripts
}

package "Classes e Funcoes (amostra)" as code <<Rectangle>> #E8F5E9 {
  component [Migration] as code_1
  component [User] as code_2
  component [Meta] as code_3
  component [__str__] as code_4
  component [full_name] as code_5
  component [is_employee] as code_6
  component [is_admin] as code_7
  component [UserProfile] as code_8
  component [UserProfileSerializer] as code_9
  component [UserSerializer] as code_10
  component [UserRegistrationSerializer] as code_11
  component [validate] as code_12
  component [create] as code_13
  component [LoginSerializer] as code_14
  component [PasswordChangeSerializer] as code_15
  component [validate_old_password] as code_16
  component [save] as code_17
  component [UserRegistrationView] as code_18
  component [login_view] as code_19
  component [logout_view] as code_20
}

note as secrets #EEEEEE
  **Dados Sigilosos**
  ---
  Credenciais, tokens, chaves
  Variaveis de ambiente
  Configs sensiveis
end note


' ====== RELACIONAMENTOS ======
frontend --> backend
main --> code
footer \\n<size:10>Sistema_de_gestao - Diagrama para portifolio (sem dados sensiveis)</size>




@enduml
