@startuml IA_mercado_3
!theme plain
skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam packageStyle rectangle
skinparam shadowing false
skinparam roundCorner 10
skinparam linetype ortho

title **IA_mercado_3**\\n<size:13>Arquitetura e Modulos Principais</size>\\n<size:11>Resumo para portifolio</size>

legend right
  |= Cor |= Camada |
  | <#1565C0> | Apresentacao |
  | <#0277BD> | Aplicacao |
  | <#00838F> | Dominio |
  | <#00695C> | Infraestrutura |
  | <#AD1457> | Observabilidade |
  | <#9E9E9E> | Dados Sigilosos (Isolado) |
end legend

package "Modulos Principais" as main <<Rectangle>> #E3F2FD {
  component [src] as src
  component [models] as models
  component [data] as data
  component [scripts] as scripts
}

package "Classes e Funcoes (amostra)" as code <<Rectangle>> #E8F5E9 {
  component [TradeResult] as code_1
  component [to_dict] as code_2
  component [_parse_tp_levels] as code_3
  component [_simulate_trade] as code_4
  component [run_backtest] as code_5
  component [_trades_to_pnl_series] as code_6
  component [compute_equity_curve] as code_7
  component [compute_drawdown] as code_8
  component [compute_metrics] as code_9
  component [pattern_statistics] as code_10
  component [_normalize_columns] as code_11
  component [load_pair_data] as code_12
  component [load_all_pairs] as code_13
  component [resample_ohlcv] as code_14
  component [build_multi_timeframe] as code_15
  component [raw_to_ohlcv_1min] as code_16
  component [convert_all_raw_to_ohlcv] as code_17
  component [add_moving_averages] as code_18
  component [add_ema] as code_19
  component [add_hv] as code_20
}

note as secrets #EEEEEE
  **Dados Sigilosos**
  ---
  Credenciais, tokens, chaves
  Variaveis de ambiente
  Configs sensiveis
end note


' ====== RELACIONAMENTOS ======
src --> models
data --> models
main --> code
footer \\n<size:10>IA_mercado_3 - Diagrama para portifolio (sem dados sensiveis)</size>




@enduml
